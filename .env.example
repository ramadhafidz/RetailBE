# Backend environment example
# Copy this file to `.env` (or set real env vars in your system) before running the server.

# Basic local credentials for development (change for production)
ALLOWED_ORIGINS=

AUTH_ADMIN_USERNAME=
AUTH_ADMIN_PASSWORD=
AUTH_USER_USERNAME=
AUTH_USER_PASSWORD=

# Secret key used to sign JWT tokens — use a long random string in production
AUTH_SECRET_KEY=change-this-secret-please-use-at-least-32-chars

# Token expiry in minutes
AUTH_TOKEN_EXPIRE_MINUTES=60

# Optional: path to GCP service account JSON (relative to repo root or absolute)
# If not provided, the code will look for credentials.json or credential.json in repo root
GCP_CREDENTIALS_PATH=
GOOGLE_APPLICATION_CREDENTIALS=

# (Optional) override project id used by gcp_service
# PROJECT_ID=
